#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
skill_content="$(cat "${PLUGIN_ROOT}/skills/orchestrator/SKILL.md" 2>/dev/null || true)"

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

body="$(printf '%s\n' "$skill_content" | awk 'BEGIN { frontmatter = 0 } /^---$/ { frontmatter++; next } frontmatter >= 2 { print }')"
context="<AGENT_ORCHESTRATOR_BOOTSTRAP>\nYou have Agent Orchestrator.\n\nUse it discreetly for delegation, swarms, model routing, setup/config, multi-agent comparison, and worktree competition. Do not force it onto ordinary tasks.\n\n${body}\n</AGENT_ORCHESTRATOR_BOOTSTRAP>"
escaped="$(escape_for_json "$context")"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
